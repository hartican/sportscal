{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sportscal.local/schemas/event-feed.schema.json",
  "title": "Sportscal event feed",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "publishedAt", "events"],
  "properties": {
    "schemaVersion": {
      "const": "events.v1"
    },
    "version": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceNote": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "eventId",
        "sport",
        "key",
        "name",
        "displayTitleCompact",
        "date",
        "time",
        "broadcaster",
        "expected",
        "liveWindow",
        "selectedSentence",
        "fullSpiel",
        "sourceName",
        "sourceUrl",
        "sourceCheckedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "eventId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "sport": {
          "type": "string",
          "minLength": 2
        },
        "key": {
          "enum": ["wimbledon", "rugby", "fifa", "f1", "tdf", "nrl", "afl", "cricket", "nba", "masters", "lemans", "nfl", "ski"]
        },
        "name": {
          "type": "string",
          "minLength": 4
        },
        "displayTitleCompact": {
          "type": "string",
          "minLength": 4,
          "maxLength": 80
        },
        "date": {
          "type": "string",
          "pattern": "^20[0-9]{2}-[0-1][0-9]-[0-3][0-9]$"
        },
        "time": {
          "type": "string",
          "pattern": "^[0-2][0-9]:[0-5][0-9]$"
        },
        "startTimeUtc": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "endTimeUtc": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "broadcaster": {
          "type": "string",
          "minLength": 2
        },
        "broadcastOptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "venue": {
          "type": ["string", "null"]
        },
        "liveWindow": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 24
        },
        "round": {
          "enum": ["all", "early", "knockout", "quarterfinal", "semifinal", "final"]
        },
        "narrativeType": {
          "type": "string",
          "minLength": 2
        },
        "selectedSentence": {
          "type": "string",
          "minLength": 20,
          "maxLength": 180
        },
        "fullSpiel": {
          "type": "string",
          "minLength": 80,
          "maxLength": 700
        },
        "sourceName": {
          "type": "string",
          "minLength": 3
        },
        "sourceUrl": {
          "type": "string",
          "pattern": "^(https?|calendar)://"
        },
        "sourceCheckedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceType": {
          "enum": ["official", "broadcaster", "reputable", "personal-calendar"]
        },
        "spoilerSafeTitle": {
          "type": "string",
          "minLength": 4,
          "maxLength": 80
        },
        "matchupParticipants": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "sourceEventId"],
            "properties": {
              "name": { "type": "string", "minLength": 2, "maxLength": 80 },
              "sourceEventId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
            }
          }
        },
        "score": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "outcomeText": {
          "type": "string",
          "minLength": 2,
          "maxLength": 180
        },
        "resultLabels": {
          "type": "array",
          "items": { "type": "string", "minLength": 2, "maxLength": 60 }
        },
        "customClassification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "calendarName", "sportRule", "eventRule"],
          "properties": {
            "schemaVersion": { "const": "calendar-events.v1" },
            "calendarName": { "type": "string", "minLength": 1, "maxLength": 80 },
            "sportRule": { "type": "string", "minLength": 1, "maxLength": 80 },
            "eventRule": { "type": "string", "minLength": 1, "maxLength": 80 }
          }
        },
        "copyReview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reviewRequired", "reviewComplete"],
          "properties": {
            "reviewRequired": {
              "type": "boolean"
            },
            "reviewComplete": {
              "type": "boolean"
            },
            "reviewer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "note": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "overrideSource": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          }
        },
        "replayEligible": {
          "type": "boolean"
        },
        "highlightEligible": {
          "type": "boolean"
        },
        "briefingEligible": {
          "type": "boolean"
        },
        "catchupEligible": {
          "type": "boolean"
        }
      }
    }
  }
}
